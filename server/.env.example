# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- Database ----
# USE_MEMORY_DB=true runs a zero-setup in-memory MongoDB (data resets on restart).
# For persistent storage: set USE_MEMORY_DB=false and point MONGODB_URI at a real database.
USE_MEMORY_DB=true
MONGODB_URI=mongodb://127.0.0.1:27017/brilliance_care

# ---- Auth ----
JWT_SECRET=super_secret_dev_key_change_me
JWT_EXPIRE=7d

# ---- Seeded admin account (powers the admin inventory panel) ----
ADMIN_NAME=Store Admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=123
